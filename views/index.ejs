<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Song 2 U — YouTube MP3 Converter</title>
  </head>
  <body>
    <div class="top-container">
      <a href="/" style="text-decoration: none; color: white">
        <h1><i class="fab fa-youtube"></i> Song 2 U</h1>
      </a>
      <h4>Insira abaixo o link do YouTube</h4>
      <div style="display: flex">
        <input
          type="text"
          id="videoUrl"
          name="videoUrl"
          placeholder="Link do YouTube"
        />
        <button type="button" id="search-btn">Buscar</button>
      </div>
    </div>

    <div class="container">
      <div id="loading" style="display: none">🔄 Carregando...</div>
      <div id="result" class="video_wrapper" style="display: none"></div>
    </div>

    <script src="/js/script.js"></script>
  </body>
</html>
